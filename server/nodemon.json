  "ext": "ts,js",
  "exec": "tsx lambda-http-server.ts",
  "ignore": ["node_modules", "dist"],
  "env": {
    "NODE_ENV": "development",
    "AWS_ENDPOINT_URL": "http://localhost:4566",
